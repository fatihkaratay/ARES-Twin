# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model identifier — flash works on free tier; upgrade to gemini-2.5-pro if billing is enabled
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API key — used in Phase 4 (self-healing refactor / PID tuning)
OPENAI_API_KEY=

# OpenAI model identifier for code refactor agent
OPENAI_MODEL=gpt-4o

# Postgres connection string (pgvector-enabled instance from docker-compose)
DATABASE_URL=postgresql+psycopg2://ares:ares@localhost:5433/ares_twin
