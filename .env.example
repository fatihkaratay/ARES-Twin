# Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model identifier — flash works on free tier; upgrade to gemini-2.5-pro if billing is enabled
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API key — used in Phase 4 (self-healing refactor / PID tuning)
OPENAI_API_KEY=

# OpenAI model identifier for code refactor agent
OPENAI_MODEL=gpt-4o

# Postgres connection string (pgvector-enabled instance from docker-compose)
DATABASE_URL=postgresql+psycopg2://ares:ares@localhost:5433/ares_twin

# Veo video generation model — fast/lite/full tiers are all preview
VEO_MODEL=veo-3.1-fast-generate-preview

# Nano Banana image generation model (terrain snapshots)
NANO_BANANA_MODEL=gemini-2.5-flash-image

# Set to true once Google Cloud billing is enabled — Veo + Nano Banana are paid-only.
# When false, triggers still fire and DB rows are recorded as status=disabled, but no API calls are made.
ENABLE_MEDIA_GENERATION=false
